[caja/window-state]
maximized=true
sidebar-width=96
start-with-sidebar=true
start-with-status-bar=true
start-with-toolbar=true

[desktop/background]
color-shading-type='solid'
primary-color='rgb(238,238,236)'
show-desktop-icons=false

[desktop/font-rendering]
antialiasing='grayscale'
hinting='slight'

[desktop/interface]
accessibility=true
enable-animations=false
gtk-decoration-layout='menu:minimize,maximize,close'
gtk-theme='HighContrast'
icon-theme='ContrastHigh'
window-scaling-factor=2

[desktop/peripherals/keyboard]
numlock-state='off'

[desktop/peripherals/mouse]
cursor-theme='mate-black'
drag-threshold=10

[desktop/session]
idle-delay=15

[notification-daemon]
popup-location='top_right'
theme='slider'

[marco/general]
button-layout='menu:minimize,maximize,close'
compositing-manager=false
num-workspaces=1
theme='HighContrast'

[panel/general]
default-layout='fedora'
object-id-list=['notification-area', 'clock', 'object-0', 'object-3', 'object-2', 'object-4', 'object-1', 'object-5', 'object-6', 'object-7']
toplevel-id-list=['top']

[panel/menubar]
icon-size='default'
item-icon-size='default'

[panel/objects/clock]
applet-iid='ClockAppletFactory::ClockApplet'
locked=true
object-type='applet'
panel-right-stick=true
position=0
toplevel-id='top'

[panel/objects/clock/prefs]
cities=@as []
custom-format=''
expand-locations=false
format='24-hour'
show-date=true
show-seconds=false
show-temperature=false
show-weather=false

[panel/objects/notification-area]
applet-iid='NotificationAreaAppletFactory::NotificationArea'
locked=true
object-type='applet'
panel-right-stick=false
position=504
toplevel-id='top'

[panel/objects/object-0]
locked=true
object-type='menu'
panel-right-stick=false
position=0
tooltip='Main Menu'
toplevel-id='top'
use-menu-path=false

[panel/objects/object-1]
applet-iid='WnckletFactory::WindowListApplet'
locked=true
object-type='applet'
panel-right-stick=false
position=110
toplevel-id='top'

[panel/objects/object-1/prefs]
display-all-workspaces=true
group-windows='always'

[panel/objects/object-2]
launcher-location='caja-browser.desktop'
locked=true
object-type='launcher'
panel-right-stick=false
position=36
toplevel-id='top'

[panel/objects/object-3]
launcher-location='xinput.desktop'
locked=true
object-type='launcher'
panel-right-stick=false
position=396
toplevel-id='top'

[panel/objects/object-4]
launcher-location='mate-terminal-1.desktop'
locked=true
object-type='launcher'
panel-right-stick=false
position=72
toplevel-id='top'

[panel/objects/object-5]
launcher-location='xdotool.desktop'
locked=true
object-type='launcher'
panel-right-stick=false
position=468
toplevel-id='top'

[panel/objects/object-6]
launcher-location='xdotool-1.desktop'
locked=true
object-type='launcher'
panel-right-stick=false
position=432
toplevel-id='top'

[panel/objects/object-7]
applet-iid='CommandAppletFactory::CommandApplet'
locked=true
object-type='applet'
panel-right-stick=false
position=546
toplevel-id='top'

[panel/objects/object-7/prefs]
command='bash /home/alpine/.local/bin/getBat.sh'
interval=60

[panel/toplevels/top]
enable-arrows=true
enable-buttons=false
expand=true
orientation='bottom'
screen=0
size=36
y=812
y-bottom=0

[pluma]
active-plugins=['modelines', 'spell', 'time', 'filebrowser', 'docinfo']
statusbar-visible=true

[screensaver]
embedded-keyboard-command='onboard --xid'
embedded-keyboard-enabled=true
lock-enabled=true
mode='blank-only'
themes=@as []

[screenshot]
border-effect='none'
delay=0
include-border=true
include-pointer=true

[terminal/profiles/default]
background-color='#FFFFFFFFDDDD'
bold-color='#000000000000'
foreground-color='#000000000000'
palette='#2E2E34343636:#CCCC00000000:#4E4E9A9A0606:#C4C4A0A00000:#34346565A4A4:#757550507B7B:#060698209A9A:#D3D3D7D7CFCF:#555557575353:#EFEF29292929:#8A8AE2E23434:#FCFCE9E94F4F:#72729F9FCFCF:#ADAD7F7FA8A8:#3434E2E2E2E2:#EEEEEEEEECEC'
visible-name='Default'
